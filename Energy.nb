Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Parallel", " ", "Energy"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Ekp", "[", 
      RowBox[{"M_", ",", "z_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox["M", "2"], "+", 
       SuperscriptBox["z", "2"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Total", " ", "Energy"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Ekr", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_", ",", "q_", ",", "M_", ",", "r_"}], 
      "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"], "+", 
       FractionBox[
        SuperscriptBox["q", "2"], "4"], "+", 
       SuperscriptBox["M", "2"], "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"r", "-", "1"}]], "*", "q", "*", 
        RowBox[{"Ekp", "[", 
         RowBox[{"M", ",", "z"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"p", "=", 
     RowBox[{"0", " ", "Case"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Ekp0byM", "[", 
      RowBox[{"Q_", ",", "r_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       FractionBox[
        SuperscriptBox["Q", "2"], "4"], "+", "1", "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"r", "-", "1"}]], "*", "Q"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     SuperscriptBox["p", 
      RowBox[{"1", ",", "2"}]], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"0", " ", "&"}], " ", 
       SuperscriptBox["p", "3"]}], "=", 
      RowBox[{"M", " ", "Case"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Ekp3byM", "[", 
      RowBox[{"Q_", ",", "r_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", "+", 
       FractionBox[
        SuperscriptBox["Q", "2"], "4"], "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"r", "-", "1"}]], "*", "Q", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     SubscriptBox["p", "T"], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"M", " ", "&"}], " ", 
       SuperscriptBox["p", "3"]}], "=", 
      RowBox[{"M", " ", "Case"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"EkpbyM", "[", 
      RowBox[{"Q_", ",", "r_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"3", "+", 
       FractionBox[
        SuperscriptBox["Q", "2"], "4"], "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"r", "-", "1"}]], "*", "Q", "*", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"DEkr", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_", ",", "Q_", ",", "zt_", ",", "r_"}], 
      "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"], "+", 
       FractionBox[
        SuperscriptBox["Q", "2"], "4"], "+", 
       SuperscriptBox["zt", "2"], "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"r", "-", "1"}]], "*", "Q", "*", 
        RowBox[{"Ekp", "[", 
         RowBox[{"zt", ",", "z"}], "]"}]}]}], "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "As", " ", "compared", " ", "to", " ", "the", " ", "previous", " ", 
      "case"}], ",", " ", 
     RowBox[{"here", " ", 
      RowBox[{"(", 
       RowBox[{"x", ",", "y", ",", "z"}], ")"}], " ", "are", " ", 
      "dimensionless", " ", 
      RowBox[{"quantities", ":", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["p", "1"], "/", "T"}], ",", 
         RowBox[{
          SuperscriptBox["p", "2"], "/", "T"}], ",", 
         RowBox[{
          SuperscriptBox["p", "3"], "/", "T"}]}], ")"}]}]}]}], 
    "*)"}]}]}]], "Input",
